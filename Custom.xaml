<!-- 日历 -->
<local:MyCard Margin="0,0,0,5">
    <Grid UseLayoutRounding="True">
        <Grid.RowDefinitions>
            <RowDefinition></RowDefinition>
            <RowDefinition></RowDefinition>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="215"></ColumnDefinition>
            <ColumnDefinition Width="5"></ColumnDefinition>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>
        <GridSplitter Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Width="5" Margin="0,0,0,20" Opacity="0"
            VerticalAlignment="Stretch" HorizontalAlignment="Center"/>
        <Calendar  HorizontalAlignment="Left" Margin="16,10,0,0" Grid.Row="0" Grid.Column="0" ></Calendar>
        <InkCanvas EditingMode="{Binding ElementName=ComboBox,Path=SelectedItem.Tag}" HorizontalAlignment="Right" Margin="0,10,16,10" Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
            Width="1024" MaxHeight="768" MinHeight="100" Background="{DynamicResource ColorBrush5}">
        </InkCanvas>
        <local:MyComboBox Name="ComboBox" Height="18" Text="选择画笔" IsEditable="False" IsDropDownOpen="False" Margin="16,0,0,10" Grid.Row="1" Grid.Column="0">            
            <local:MyComboBoxItem Tag="Ink" Content="&gt; &gt; 绘 制 墨 迹 &lt; &lt;" IsSelected="True"/>
            <local:MyComboBoxItem Tag="EraseByPoint" Content="&gt; &gt; 按 点 擦 除 &lt; &lt;"/>
            <local:MyComboBoxItem Tag="EraseByStroke" Content="&gt; &gt; 按 线 擦 除 &lt; &lt;"/>
            <local:MyComboBoxItem Tag="Select" Content="&gt; &gt; 选 中 墨 迹 &lt; &lt;"/>
            <local:MyComboBoxItem Tag="None" Content="&gt; &gt; 停 止 操 作 &lt; &lt;"/>
        </local:MyComboBox>
    </Grid>
</local:MyCard>

