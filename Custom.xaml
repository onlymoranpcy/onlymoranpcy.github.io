<!-- 欢迎 -->
<StackPanel>
	<StackPanel Margin="0,-10,0,0">
	<!-- 闪烁切换效果 -->
    <StackPanel.Triggers>
      <EventTrigger RoutedEvent="StackPanel.Loaded">
        <BeginStoryboard>
          <Storyboard x:Name="animation1" RepeatBehavior="Forever">
            <ColorAnimation Storyboard.TargetName="Text1" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="#FF000000" To="#FF000000" Duration="0:0:0" />
            <ColorAnimation BeginTime="0:0:5" Storyboard.TargetName="Text1" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="#FF000000" To="#00000000" Duration="0:0:1" />
            <ColorAnimation BeginTime="0:0:13" Storyboard.TargetName="Text1" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="#00000000" To="#FF000000" Duration="0:0:1" />
            <ColorAnimation Storyboard.TargetName="Text2" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="#00000000" To="#00000000" Duration="0:0:0" />
            <ColorAnimation BeginTime="0:0:6" Storyboard.TargetName="Text2" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="#00000000" To="#FF000000" Duration="0:0:1" />
            <ColorAnimation BeginTime="0:0:12" Storyboard.TargetName="Text2" Storyboard.TargetProperty="(TextBlock.Foreground).(SolidColorBrush.Color)" From="#FF000000" To="#00000000" Duration="0:0:1" />
          </Storyboard>
        </BeginStoryboard>
      </EventTrigger>
    </StackPanel.Triggers>
	
